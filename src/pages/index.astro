---
import BaseLayout from '@/layouts/BaseLayout.astro';
import { getCollection, type CollectionEntry } from 'astro:content';
import HeroSection from '@/components/home/HeroSection';
import VerticalCards from '@/components/home/VerticalCards';
import FeaturedProperties from '@/components/home/FeaturedProperties';
import { SocialProof } from '@/components/home/SocialProof';
import DestinationHighlights from '@/components/home/DestinationHighlights';

// Load content collections
const properties = await getCollection('properties');
const regions = await getCollection('regions');
const destinationConfigs = await getCollection('destinationConfigs');
const cityConfigs = await getCollection('cityConfigs');

// Prepare featured properties (3–6 items)
const featuredProperties = properties.slice(0, 6).map((p: CollectionEntry<'properties'>) => ({
  name: p.data.name,
  slug: p.id,
  region: p.data.region,
  priceRange: p.data.priceRange,
  wowFactor: p.data.wowFactor,
  stayType: p.data.stayType,
}));

// Prepare social proof metrics
const metrics = [
  { label: 'Cities', value: cityConfigs.length, suffix: '+' },
  { label: 'Properties', value: properties.length, suffix: '+' },
  { label: 'Destinations', value: destinationConfigs.length + regions.length, suffix: '+' },
];

// Prepare region data for DestinationHighlights
const regionData = regions.map((r: CollectionEntry<'regions'>) => ({
  name: r.data.name,
  slug: r.id,
}));

// Prepare destination data for DestinationHighlights
const destinationData = destinationConfigs.map((d: CollectionEntry<'destinationConfigs'>) => ({
  name: d.data.name,
  slug: d.data.slug,
  scope: d.data.scope,
}));

// Select at least 3 regions for footer links
const footerRegions = regions.slice(0, 4).map((r: CollectionEntry<'regions'>) => ({
  name: r.data.name,
  slug: r.id,
}));
---

<BaseLayout
  title="Basecamp Atlas"
  description="Basecamp Atlas is a lifestyle discovery platform for Charlotte-area living and curated mountain retreats within driving distance."
>
  <!-- Hero Section -->
  <HeroSection client:visible />

  <!-- Vertical Entry Cards -->
  <VerticalCards client:visible />

  <!-- Featured Properties -->
  {featuredProperties.length > 0 && (
    <FeaturedProperties client:visible properties={featuredProperties} />
  )}

  <!-- Social Proof Metrics -->
  <SocialProof client:visible metrics={metrics} />

  <!-- Destination Highlights -->
  <DestinationHighlights client:visible regions={regionData} destinations={destinationData} />

  <!-- Footer -->
  <footer
    class="border-t px-6 py-16 md:py-20"
    style="background: var(--surface-base, #0f172a); border-color: var(--border-subtle, rgba(30, 41, 59, 0.6));"
  >
    <div class="mx-auto max-w-6xl">
      <div class="grid grid-cols-1 gap-10 sm:grid-cols-2 lg:grid-cols-4">
        <!-- About -->
        <div class="sm:col-span-2 lg:col-span-1">
          <h4
            class="mb-3 text-lg font-bold"
            style="color: var(--text-primary, #e2e8f0); font-family: Playfair Display, serif;"
          >
            Basecamp Atlas
          </h4>
          <p class="text-sm leading-relaxed" style="color: var(--text-secondary, #94a3b8);">
            A lifestyle discovery platform pairing Charlotte apartment living with curated nature retreats in the Southern Appalachians — all within driving distance.
          </p>
        </div>

        <!-- Verticals -->
        <div>
          <h5
            class="mb-3 text-xs font-medium uppercase tracking-widest"
            style="color: var(--text-secondary, #94a3b8);"
          >
            Explore
          </h5>
          <nav aria-label="Vertical navigation">
            <ul class="space-y-2">
              <li>
                <a
                  href="/live"
                  class="text-sm transition-colors hover:underline"
                  style="color: var(--text-primary, #e2e8f0);"
                >
                  Live — Apartments
                </a>
              </li>
              <li>
                <a
                  href="/escape"
                  class="text-sm transition-colors hover:underline"
                  style="color: var(--text-primary, #e2e8f0);"
                >
                  Escape — Retreats
                </a>
              </li>
            </ul>
          </nav>
        </div>

        <!-- Destination Regions -->
        <div>
          <h5
            class="mb-3 text-xs font-medium uppercase tracking-widest"
            style="color: var(--text-secondary, #94a3b8);"
          >
            Regions
          </h5>
          <nav aria-label="Region navigation">
            <ul class="space-y-2">
              {footerRegions.map((region: { name: string; slug: string }) => (
                <li>
                  <a
                    href={`/escape/${region.slug}`}
                    class="text-sm transition-colors hover:underline"
                    style="color: var(--text-primary, #e2e8f0);"
                  >
                    {region.name}
                  </a>
                </li>
              ))}
            </ul>
          </nav>
        </div>

        <!-- Destinations -->
        <div>
          <h5
            class="mb-3 text-xs font-medium uppercase tracking-widest"
            style="color: var(--text-secondary, #94a3b8);"
          >
            Destinations
          </h5>
          <nav aria-label="Destination navigation">
            <ul class="space-y-2">
              <li>
                <a
                  href="/escape/destinations"
                  class="text-sm transition-colors hover:underline"
                  style="color: var(--text-primary, #e2e8f0);"
                >
                  All Destinations
                </a>
              </li>
            </ul>
          </nav>
        </div>
      </div>

      <!-- Bottom bar -->
      <div
        class="mt-12 border-t pt-6 text-center text-xs"
        style="border-color: var(--border-subtle, rgba(30, 41, 59, 0.6)); color: var(--text-muted, #64748b);"
      >
        © {new Date().getFullYear()} Basecamp Atlas. All rights reserved.
      </div>
    </div>
  </footer>

  <!-- JSON-LD Structured Data -->
  <script type="application/ld+json" is:inline slot="json-ld" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "WebSite",
    "name": "Basecamp Atlas",
    "url": "https://basecamp-atlas.vercel.app",
    "description": "A lifestyle discovery platform pairing Charlotte apartment living with curated nature retreats in the Southern Appalachians.",
    "potentialAction": {
      "@type": "SearchAction",
      "target": "https://basecamp-atlas.vercel.app/escape?q={search_term_string}",
      "query-input": "required name=search_term_string"
    }
  })} />
</BaseLayout>
