---
import { getCollection, render } from 'astro:content';
import PropertyLayout from '@/layouts/PropertyLayout.astro';
import { formatDriveTime } from '@/lib/drive-time';

export async function getStaticPaths() {
  const allProperties = await getCollection('properties');
  const allRegions = await getCollection('regions');

  return allProperties.map((property) => {
    const region = allRegions.find((r) => r.id === property.data.region);
    return {
      params: {
        region: property.data.region,
        property: property.id,
      },
      props: {
        property,
        regionEntry: region,
      },
    };
  });
}

const { property, regionEntry } = Astro.props;
const { data } = property;

// Render the Markdown body
const { Content } = await render(property);

// Look up origin city names for drive time display
const allOriginCities = await getCollection('originCities');
const originCityMap = new Map(
  allOriginCities.map((city) => [city.data.slug, city.data.name])
);

// Sort drive times by shortest first
const sortedDriveTimes = Object.entries(data.driveTimes)
  .sort(([, a], [, b]) => a - b)
  .map(([slug, minutes]) => ({
    cityName: originCityMap.get(slug) || slug,
    formatted: formatDriveTime(minutes),
    minutes,
  }));

// Region name for breadcrumb
const regionName = regionEntry?.data.name ?? data.region;

// Breadcrumb items
const breadcrumbs = [
  { label: 'Escape', href: '/escape' },
  { label: regionName, href: `/escape/${data.region}` },
  { label: data.name, href: `/escape/${data.region}/${property.id}` },
];

// Privacy dots helper
const privacyDots = Array.from({ length: 5 }, (_, i) => i < data.privacyLevel);
---

<PropertyLayout
  title={`${data.name} | Basecamp Atlas`}
  description={data.wowFactor}
  breadcrumbs={breadcrumbs}
>
  <!-- Main Content (left column) -->
  <Fragment slot="content">
    <!-- Property Name -->
    <h1
      class="text-3xl md:text-4xl font-bold font-[family-name:var(--font-heading,Playfair_Display)]"
      style="color: var(--text-primary);"
    >
      {data.name}
    </h1>

    <!-- Stay Type Badge & Region -->
    <div class="flex flex-wrap items-center gap-3 mt-4">
      <span
        class="inline-block px-3 py-1 text-sm font-medium rounded-full"
        style="background-color: var(--accent-primary); color: var(--surface-base);"
      >
        {data.stayType}
      </span>
      <span class="text-sm" style="color: var(--text-secondary);">
        {regionName}
      </span>
    </div>

    <!-- Editorial Body (Markdown) -->
    <article class="prose prose-invert mt-8 max-w-none" style="color: var(--text-secondary);">
      <Content />
    </article>

    <!-- Amenity Pills -->
    <section class="mt-8" aria-label="Amenities">
      <h2
        class="text-lg font-semibold mb-3 font-[family-name:var(--font-heading,Playfair_Display)]"
        style="color: var(--text-primary);"
      >
        Amenities
      </h2>
      <div class="flex flex-wrap gap-2">
        {data.amenities.map((amenity) => (
          <span
            class="inline-block px-3 py-1 text-sm rounded-full"
            style="background-color: var(--surface-elevated); color: var(--text-secondary); border: 1px solid var(--border-subtle);"
          >
            {amenity}
          </span>
        ))}
      </div>
    </section>

    <!-- Nearby Hikes -->
    {data.nearbyHikes && data.nearbyHikes.length > 0 && (
      <section class="mt-8" aria-label="Nearby hikes and activities">
        <h2
          class="text-lg font-semibold mb-3 font-[family-name:var(--font-heading,Playfair_Display)]"
          style="color: var(--text-primary);"
        >
          Nearby Hikes & Activities
        </h2>
        <ul class="space-y-2">
          {data.nearbyHikes.map((hike) => (
            <li class="flex items-baseline gap-2" style="color: var(--text-secondary);">
              <span class="shrink-0" style="color: var(--accent-secondary);">•</span>
              <span>{hike.name}</span>
              {hike.distance && (
                <span class="text-sm ml-auto shrink-0" style="color: var(--text-muted);">
                  {hike.distance}
                </span>
              )}
            </li>
          ))}
        </ul>
      </section>
    )}

    <!-- Wow Factor Callout -->
    <section class="mt-8" aria-label="Wow factor">
      <blockquote
        class="border-l-4 pl-4 py-2 italic text-lg"
        style="border-color: var(--accent-primary); color: var(--text-primary);"
      >
        {data.wowFactor}
      </blockquote>
    </section>
  </Fragment>

  <!-- Sidebar (right column) -->
  <Fragment slot="sidebar">
    <div class="space-y-6">
      <!-- Price Range -->
      <div
        class="p-4 rounded-lg"
        style="background-color: var(--surface-elevated); border: 1px solid var(--border-subtle);"
      >
        <p class="text-sm mb-1" style="color: var(--text-muted);">Per night</p>
        <p class="text-2xl font-bold" style="color: var(--accent-primary);">
          ${data.priceRange.min}–${data.priceRange.max}
        </p>
      </div>

      <!-- Privacy Level -->
      <div
        class="p-4 rounded-lg"
        style="background-color: var(--surface-elevated); border: 1px solid var(--border-subtle);"
      >
        <p class="text-sm mb-2" style="color: var(--text-muted);">Privacy Level</p>
        <div class="flex gap-1.5" aria-label={`Privacy level ${data.privacyLevel} out of 5`}>
          {privacyDots.map((filled) => (
            <span
              class="w-3 h-3 rounded-full"
              style={filled
                ? 'background-color: var(--accent-primary);'
                : 'background-color: var(--surface-overlay); border: 1px solid var(--border-default);'}
            />
          ))}
        </div>
      </div>

      <!-- Road Access -->
      <div
        class="p-4 rounded-lg"
        style="background-color: var(--surface-elevated); border: 1px solid var(--border-subtle);"
      >
        <p class="text-sm mb-1" style="color: var(--text-muted);">Road Access</p>
        <p class="text-sm font-medium capitalize" style="color: var(--text-primary);">
          {data.roadAccess}
        </p>
      </div>

      <!-- Drive Times -->
      <div
        class="p-4 rounded-lg"
        style="background-color: var(--surface-elevated); border: 1px solid var(--border-subtle);"
      >
        <p class="text-sm mb-3" style="color: var(--text-muted);">Drive Times</p>
        <ul class="space-y-2">
          {sortedDriveTimes.map((dt) => (
            <li class="flex justify-between items-center text-sm">
              <span style="color: var(--text-secondary);">{dt.cityName}</span>
              <span class="font-medium" style="color: var(--text-primary);">{dt.formatted}</span>
            </li>
          ))}
        </ul>
      </div>

      <!-- Seasonal Tags (optional) -->
      {data.seasonalTags && data.seasonalTags.length > 0 && (
        <div
          class="p-4 rounded-lg"
          style="background-color: var(--surface-elevated); border: 1px solid var(--border-subtle);"
        >
          <p class="text-sm mb-2" style="color: var(--text-muted);">Best Seasons</p>
          <div class="flex flex-wrap gap-2">
            {data.seasonalTags.map((tag) => (
              <span
                class="inline-block px-2 py-0.5 text-xs rounded-full capitalize"
                style="background-color: var(--accent-secondary); color: var(--surface-base);"
              >
                {tag}
              </span>
            ))}
          </div>
        </div>
      )}

      <!-- Booking CTA -->
      <a
        href={data.bookingUrl}
        target="_blank"
        rel="noopener noreferrer"
        class="block w-full text-center px-6 py-3 rounded-lg font-medium text-lg transition-opacity hover:opacity-90"
        style="background-color: var(--accent-primary); color: var(--surface-base);"
      >
        Book This Stay
      </a>
    </div>
  </Fragment>
</PropertyLayout>
