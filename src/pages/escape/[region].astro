---
import { getCollection } from 'astro:content';
import VerticalLayout from '@/layouts/VerticalLayout.astro';
import { formatDriveTime } from '@/lib/drive-time';

export async function getStaticPaths() {
  const allRegions = await getCollection('regions');
  const allProperties = await getCollection('properties');

  // Only generate pages for regions that have at least 1 property
  return allRegions
    .filter((region) => {
      const regionProperties = allProperties.filter(
        (p) => p.data.region === region.id
      );
      return regionProperties.length > 0;
    })
    .map((region) => {
      const regionProperties = allProperties.filter(
        (p) => p.data.region === region.id
      );
      return {
        params: { region: region.id },
        props: { region, properties: regionProperties },
      };
    });
}

const { region, properties } = Astro.props;
const { data } = region;

// Look up origin city names for drive time display
const allOriginCities = await getCollection('originCities');
const originCityMap = new Map(
  allOriginCities.map((city) => [city.data.slug, city.data.name])
);
---

<VerticalLayout
  vertical="escape"
  title={`${data.name} Retreats | Basecamp Atlas`}
  description={data.description}
>
  <div class="max-w-7xl mx-auto px-4 py-8">
    <!-- Breadcrumb -->
    <nav class="mb-6 text-sm" aria-label="Breadcrumb">
      <ol class="flex items-center gap-2" style="color: var(--text-muted);">
        <li>
          <a href="/escape" class="hover:underline" style="color: var(--accent-primary);">
            Escape
          </a>
        </li>
        <li aria-hidden="true">→</li>
        <li aria-current="page" style="color: var(--text-secondary);">
          {data.name}
        </li>
      </ol>
    </nav>

    <!-- Region Intro -->
    <header class="mb-10">
      <h1
        class="text-3xl md:text-4xl font-bold font-[family-name:var(--font-heading,Playfair_Display)]"
        style="color: var(--text-primary);"
      >
        {data.name}
      </h1>
      <p class="mt-4 text-lg leading-relaxed max-w-3xl" style="color: var(--text-secondary);">
        {data.description}
      </p>

      <!-- Highlights -->
      {data.highlights && data.highlights.length > 0 && (
        <section class="mt-6" aria-label="Region highlights">
          <h2
            class="text-lg font-semibold mb-3 font-[family-name:var(--font-heading,Playfair_Display)]"
            style="color: var(--text-primary);"
          >
            Highlights
          </h2>
          <ul class="grid grid-cols-1 sm:grid-cols-2 gap-2">
            {data.highlights.map((highlight) => (
              <li class="flex items-center gap-2 text-sm" style="color: var(--text-secondary);">
                <span style="color: var(--accent-primary);">•</span>
                {highlight}
              </li>
            ))}
          </ul>
        </section>
      )}
    </header>

    <!-- Properties Grid -->
    <section aria-label={`Properties in ${data.name}`}>
      <h2
        class="text-xl font-semibold mb-6 font-[family-name:var(--font-heading,Playfair_Display)]"
        style="color: var(--text-primary);"
      >
        {properties.length} {properties.length === 1 ? 'Property' : 'Properties'}
      </h2>

      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
        {properties.map((property) => {
          const propData = property.data;
          const detailUrl = `/escape/${propData.region}/${property.id}`;
          const wowExcerpt =
            propData.wowFactor.length > 120
              ? propData.wowFactor.slice(0, 120).trimEnd() + '…'
              : propData.wowFactor;

          // Get shortest drive time for display
          const driveEntries = Object.entries(propData.driveTimes).sort(
            ([, a], [, b]) => a - b
          );
          const shortestDrive = driveEntries[0];

          return (
            <article
              class="rounded-lg p-5 transition-colors"
              style="background-color: var(--surface-elevated); border: 1px solid var(--border-subtle);"
            >
              {/* Header */}
              <div class="flex items-start justify-between gap-2 mb-3">
                <h3
                  class="text-base font-bold font-[family-name:var(--font-heading,Playfair_Display)]"
                  style="color: var(--text-primary);"
                >
                  {propData.name}
                </h3>
                <span
                  class="shrink-0 inline-block px-2 py-0.5 text-[10px] uppercase tracking-wider rounded-full font-medium"
                  style="background-color: var(--accent-secondary); color: var(--text-primary);"
                >
                  {propData.stayType}
                </span>
              </div>

              {/* Price range */}
              <div class="text-sm mb-3">
                <span class="font-semibold" style="color: var(--accent-primary);">
                  ${propData.priceRange.min}–${propData.priceRange.max}
                </span>
                <span style="color: var(--text-muted);">/night</span>
              </div>

              {/* Privacy dots */}
              <div class="flex items-center gap-2 mb-3">
                <span class="text-xs uppercase tracking-wider" style="color: var(--text-muted);">
                  Privacy
                </span>
                <div
                  class="flex items-center gap-1"
                  aria-label={`Privacy level ${propData.privacyLevel} out of 5`}
                >
                  {Array.from({ length: 5 }, (_, i) => (
                    <span
                      class={`inline-block w-2 h-2 rounded-full`}
                      style={
                        i < propData.privacyLevel
                          ? 'background-color: var(--accent-primary);'
                          : 'background-color: var(--border-subtle); opacity: 0.5;'
                      }
                    />
                  ))}
                </div>
              </div>

              {/* Shortest drive time */}
              {shortestDrive && (
                <div class="flex items-center gap-2 text-sm mb-3" style="color: var(--text-secondary);">
                  <span style="color: var(--accent-primary);">⏱</span>
                  <span>
                    {formatDriveTime(shortestDrive[1])} from{' '}
                    {originCityMap.get(shortestDrive[0]) || shortestDrive[0]}
                  </span>
                </div>
              )}

              {/* Wow factor excerpt */}
              <p class="text-sm leading-relaxed mb-4 line-clamp-3" style="color: var(--text-secondary);">
                {wowExcerpt}
              </p>

              {/* Detail link */}
              <a
                href={detailUrl}
                class="inline-flex items-center gap-1 text-sm font-medium transition-colors"
                style="color: var(--accent-primary);"
              >
                View details →
              </a>
            </article>
          );
        })}
      </div>
    </section>
  </div>
</VerticalLayout>
