---
import BaseLayout from './BaseLayout.astro';
import Navigation from '@/components/shared/Navigation.tsx';
import { loadVerticals } from '@/lib/verticals';
import { getCollection } from 'astro:content';

interface Props {
  vertical: string;
  title: string;
  description?: string;
  ogTitle?: string;
  ogDescription?: string;
  ogType?: string;
  ogUrl?: string;
  canonical?: string;
}

const {
  vertical,
  title,
  description,
  ogTitle,
  ogDescription,
  ogType,
  ogUrl,
  canonical,
} = Astro.props;

const verticals = loadVerticals();

const cityConfigs = await getCollection('cityConfigs');
const cities = cityConfigs.map((c: { data: { name: string; slug: string } }) => ({ name: c.data.name, slug: c.data.slug }));

const destinationConfigs = await getCollection('destinationConfigs');
const destinations = destinationConfigs.map((d: { data: { name: string; slug: string } }) => ({ name: d.data.name, slug: d.data.slug }));
---

<BaseLayout
  title={title}
  description={description}
  ogTitle={ogTitle}
  ogDescription={ogDescription}
  ogType={ogType}
  ogUrl={ogUrl}
  canonical={canonical}
>
  <div data-vertical={vertical}>
    <Navigation client:load verticals={verticals} activeVertical={vertical} cities={cities} destinations={destinations} />
    <main class="pt-16">
      <slot />
    </main>
  </div>
</BaseLayout>
